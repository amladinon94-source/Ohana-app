{
  "name": "ohana",
  "version": "0.10.0",
  "description": "Ohana — Superpowered HTML + React preview for designers working with an AI agent",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amladinon94-source/Ohana-app.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "test": "node --test test/*.test.mjs",
    "test:webview": "electron test/webview-harness.js",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^3.6.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.designer.ohana",
    "productName": "Ohana",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Ohana",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "examples/onboarding.html",
      "examples/design.md"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "directories": {
      "output": "dist"
    },
    "fileAssociations": [
      {
        "ext": "html",
        "name": "HTML File",
        "role": "Viewer"
      },
      {
        "ext": "htm",
        "name": "HTM File",
        "role": "Viewer"
      }
    ]
  },
  "author": "Designer",
  "license": "MIT"
}
